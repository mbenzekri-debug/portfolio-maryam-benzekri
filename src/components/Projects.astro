---
/**
 * Projects grid with decorative numbering and action links.
 */
import { projects } from "../utils/view-model";
---

<section id="projects" class="section container" data-reveal>
  <h2 class="section-title">Projets</h2>
  <div class="project-grid">
    {projects.map((project, index) => (
      <article class="glass card-hover project-card">
        <span class="project-card__watermark gradient-text mono">{String(index + 1).padStart(2, "0")}</span>
        <h3>{project.url ? <a href={project.url} target="_blank" rel="noreferrer noopener">{project.title} ↗</a> : project.title}</h3>
        <p>{project.description}</p>
        <div class="project-card__tags">{project.tags.map((tag) => <span>{tag}</span>)}</div>
        {project.url && <a href={project.url} target="_blank" rel="noreferrer noopener" class="project-card__cta">View Project →</a>}
      </article>
    ))}
  </div>
</section>

<style>
  .project-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1rem; }
  .project-card { padding: 1rem; position: relative; }
  .project-card__watermark { position: absolute; top: .7rem; right: .8rem; font-size: 2.2rem; opacity: .18; }
  .project-card p { color: var(--muted); }
  .project-card__tags { display: flex; flex-wrap: wrap; gap: .4rem; }
  .project-card__tags span { border: 1px solid var(--border); border-radius: 999px; padding: .2rem .55rem; font-size: .8rem; }
  .project-card__cta { margin-top: .65rem; display: inline-flex; color: #d9ccff; }
  @media (max-width: 768px) { .project-grid { grid-template-columns: 1fr; } }
</style>
