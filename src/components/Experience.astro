---
/**
 * Professional experience cards with accent rail.
 */
import { experience } from "../utils/view-model";
---

<section id="experience" class="section container" data-reveal>
  <h2 class="section-title">Expérience</h2>
  <div class="exp-grid">
    {experience.map((item) => (
      <article class="glass card-hover exp-card">
        <div class="exp-card__meta">
          <span class="mono">{item.period}</span>
          {item.current && <span class="badge">Current</span>}
        </div>
        <h3>{item.role}</h3>
        <p>
          {item.organizationUrl ? <a href={item.organizationUrl} target="_blank" rel="noreferrer noopener">{item.organization} ↗</a> : item.organization}
        </p>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .exp-grid { display: grid; gap: 1rem; }
  .exp-card { padding: 1rem; border-left: 3px solid transparent; border-image: var(--gradient-main) 1; }
  .exp-card:hover { transform: translateX(6px); }
  .exp-card__meta { display: flex; gap: .55rem; align-items: center; }
  .exp-card p { margin: .35rem 0 0; color: var(--muted); }
  .badge { border-radius: 999px; border: 1px solid var(--border); padding: .1rem .5rem; font-size: .75rem; }
</style>
