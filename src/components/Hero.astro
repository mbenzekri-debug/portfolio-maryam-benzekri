---
/**
 * Full-screen hero with profile intro, social pills and adaptive CTA buttons.
 */
import { profile, social } from "../utils/view-model";

const iconMap: Record<string, string> = {
  github: "M9 19c-5 1.5-5-2.5-7-3m14 6v-4a3.5 3.5 0 0 0-1-2.5c3.3-.4 6.8-1.6 6.8-7.2A5.7 5.7 0 0 0 20 4.8 5.2 5.2 0 0 0 19.9 1s-1.3-.4-4.2 1.6a14.5 14.5 0 0 0-7.6 0C5.2.6 3.9 1 3.9 1A5.2 5.2 0 0 0 3.8 4.8a5.7 5.7 0 0 0-1.5 3.9c0 5.6 3.5 6.8 6.8 7.2a3.5 3.5 0 0 0-1 2.5v4",
  linkedin: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 1 0-4 0v7h-4V9h4v2a5 5 0 0 1 2-1zM2 9h4v12H2zM4 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z",
  twitter: "M22 5.9a8.5 8.5 0 0 1-2.5.7 4.3 4.3 0 0 0 1.9-2.4 8.7 8.7 0 0 1-2.8 1.1 4.3 4.3 0 0 0-7.4 3 4 4 0 0 0 .1 1A12.3 12.3 0 0 1 3 5.2a4.3 4.3 0 0 0 1.3 5.7 4.2 4.2 0 0 1-2-.6v.1a4.3 4.3 0 0 0 3.5 4.2 4.3 4.3 0 0 1-1.9.1 4.3 4.3 0 0 0 4 3 8.6 8.6 0 0 1-5.4 1.9A9 9 0 0 1 2 19a12.2 12.2 0 0 0 6.6 1.9c8 0 12.3-6.6 12.3-12.3v-.6A8.7 8.7 0 0 0 22 5.9z",
  globe: "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm-8 10h16M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z",
  scholar: "M12 3L2 9l10 6 10-6-10-6zm0 8.2L4.4 9 12 4.8 19.6 9 12 11.2zM4 12v4l8 5 8-5v-4",
  orcid: "M4 4h5v16H4zM11 8h5a4 4 0 1 1 0 8h-5z",
  researchgate: "M4 19V5h8a4 4 0 1 1 0 8h-4l6 6",
  mail: "M4 6h16v12H4zM4 8l8 5 8-5"
};

const ctaButtons = [
  { label: "Voir mes Projets", href: "#projects", active: true },
  { label: "Télécharger mon CV", href: profile.personal.cvUrl || "#", active: Boolean(profile.personal.cvUrl) },
  { label: "Me Contacter", href: "#contact", active: true }
].filter((item) => item.active);
---

<section id="hero" class="section hero container" data-reveal>
  <div class="hero__grid">
    <div class="hero__content">
      <span class="hero__availability"><i></i>{profile.personal.availability}</span>
      <h1 class="hero__name gradient-text">{profile.personal.firstName} {profile.personal.lastName}</h1>
      <h2>{profile.personal.title}</h2>
      <p>{profile.personal.subtitle}</p>

      <div class="hero__actions">
        {ctaButtons.map((btn) => (
          <a href={btn.href} class="hero__btn">{btn.label}</a>
        ))}
      </div>

      {social.length > 0 && (
        <div class="hero__socials">
          {social.map((item) => (
            <a href={item.url} target="_blank" rel="noreferrer noopener" class="glass">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d={iconMap[item.icon]} /></svg>
              <span>{item.label}</span>
            </a>
          ))}
        </div>
      )}

      <div class="hero__stats glass">
        {profile.stats.map((stat) => (
          <div>
            <strong class="gradient-text">{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hero__avatar-wrap">
      <div class="hero__avatar-ring">
        <img src={profile.personal.avatar} alt={`Photo de ${profile.personal.firstName} ${profile.personal.lastName}`} loading="lazy" />
      </div>
    </div>
  </div>
  <a href="#about" class="hero__scroll" aria-label="Descendre">
    <span></span>
  </a>
</section>

<style>
  .hero { min-height: calc(100vh - 5rem); display: grid; align-items: center; }
  .hero__grid { display: grid; grid-template-columns: 1.25fr 0.75fr; gap: 2rem; align-items: center; }
  .hero__availability { display: inline-flex; gap: .45rem; align-items: center; padding: .35rem .75rem; border: 1px solid var(--border); border-radius: 999px; margin-bottom: 1rem; }
  .hero__availability i { width: .55rem; height: .55rem; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 0 rgba(34, 197, 94, .6); animation: pulse 1.8s infinite; }
  .hero__name { font-size: clamp(2.2rem, 6vw, 4rem); margin: 0 0 .8rem; background-size: 200% 200%; animation: gradientShift 5s ease infinite; }
  .hero h2 { margin: 0 0 .75rem; font-size: clamp(1.05rem, 2.5vw, 1.5rem); }
  .hero p { color: var(--muted); max-width: 60ch; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: .7rem; margin: 1.2rem 0; }
  .hero__btn { padding: .62rem 1rem; border-radius: .75rem; border: 1px solid var(--border); background: rgba(139, 92, 246, .18); transition: .2s ease; }
  .hero__btn:hover { transform: translateY(-2px); box-shadow: var(--glow); }
  .hero__socials { display: flex; flex-wrap: wrap; gap: .6rem; }
  .hero__socials a { display: inline-flex; align-items: center; gap: .5rem; padding: .45rem .7rem; border-radius: 999px; }
  .hero__socials svg { width: 1rem; height: 1rem; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .hero__stats { margin-top: 1rem; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .75rem; padding: .9rem; }
  .hero__stats strong { display: block; font-size: 1.2rem; }
  .hero__stats span { color: var(--muted); font-size: .88rem; }
  .hero__avatar-wrap { display: grid; place-items: center; }
  .hero__avatar-ring { padding: .3rem; border-radius: 50%; background: var(--gradient-main); animation: hue 7s linear infinite; transition: transform .35s cubic-bezier(.2,.7,.2,1.25); }
  .hero__avatar-ring:hover { transform: scale(1.04); }
  .hero__avatar-ring img { width: min(320px, 78vw); aspect-ratio: 1; object-fit: cover; border-radius: 50%; border: 4px solid var(--bg); display: block; }
  .hero__scroll { position: absolute; left: 50%; transform: translateX(-50%); bottom: 1.2rem; width: 1.9rem; height: 3rem; border: 1px solid var(--border); border-radius: 1rem; display: grid; place-items: center; }
  .hero__scroll span { width: .35rem; height: .35rem; border-radius: 50%; background: var(--accent); animation: scrollDot 1.4s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, .6); } 70% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); } 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); } }
  @keyframes gradientShift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
  @keyframes hue { to { filter: hue-rotate(360deg); } }
  @keyframes scrollDot { 0%,100% { transform: translateY(-4px); opacity: .4;} 50% { transform: translateY(6px); opacity: 1; } }
  @media (max-width: 900px) {
    .hero__grid { grid-template-columns: 1fr; }
    .hero__avatar-wrap { order: -1; }
    .hero__stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>
