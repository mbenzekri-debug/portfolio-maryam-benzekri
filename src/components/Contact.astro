---
/**
 * Contact section with info cards and functional form endpoint.
 */
import { profile, social } from "../utils/view-model";

const iconMap: Record<string, string> = {
  mail: "M4 6h16v12H4zM4 8l8 5 8-5",
  phone: "M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.7.6 2.6a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6.1 6.1l1.5-1.2a2 2 0 0 1 2.1-.5c.9.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2z",
  map: "M9 18l-6 3V6l6-3 6 3 6-3v15l-6 3-6-3z",
  github: "M9 19c-5 1.5-5-2.5-7-3m14 6v-4a3.5 3.5 0 0 0-1-2.5c3.3-.4 6.8-1.6 6.8-7.2A5.7 5.7 0 0 0 20 4.8 5.2 5.2 0 0 0 19.9 1s-1.3-.4-4.2 1.6a14.5 14.5 0 0 0-7.6 0C5.2.6 3.9 1 3.9 1A5.2 5.2 0 0 0 3.8 4.8a5.7 5.7 0 0 0-1.5 3.9c0 5.6 3.5 6.8 6.8 7.2a3.5 3.5 0 0 0-1 2.5v4",
  linkedin: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 1 0-4 0v7h-4V9h4v2a5 5 0 0 1 2-1zM2 9h4v12H2zM4 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z",
  globe: "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z",
  twitter: "M22 5.9a8.5 8.5 0 0 1-2.5.7"
};

const primaryEmail = profile.personal.emails[0] ?? "";
---

<section id="contact" class="section container" data-reveal>
  <h2 class="section-title">Contact</h2>
  <div class="contact-grid">
    <div class="contact-info">
      <article class="glass card-hover info-card">
        <span><svg viewBox="0 0 24 24"><path d={iconMap.mail} /></svg></span>
        <div><h3>Email</h3><p>{primaryEmail}</p></div>
      </article>
      {profile.personal.phone && (
        <article class="glass card-hover info-card">
          <span><svg viewBox="0 0 24 24"><path d={iconMap.phone} /></svg></span>
          <div><h3>Téléphone</h3><p>{profile.personal.phone}</p></div>
        </article>
      )}
      <article class="glass card-hover info-card">
        <span><svg viewBox="0 0 24 24"><path d={iconMap.map} /></svg></span>
        <div><h3>Localisation</h3><p>{profile.personal.location}</p></div>
      </article>

      {social.length > 0 && (
        <div class="social-band">
          {social.map((item) => (
            <a href={item.url} target="_blank" rel="noreferrer noopener" class="glass">
              <svg viewBox="0 0 24 24"><path d={iconMap[item.icon] ?? iconMap.globe} /></svg>
            </a>
          ))}
        </div>
      )}
    </div>

    <form class="glass contact-form" action={`https://formsubmit.co/${primaryEmail}`} method="POST">
      <input type="hidden" name="_captcha" value="false" />
      <label>Nom<input name="name" type="text" required /></label>
      <label>Email<input name="email" type="email" required /></label>
      <label>Sujet<input name="subject" type="text" required /></label>
      <label>Message<textarea name="message" rows="6" required></textarea></label>
      <button type="submit">Envoyer ✈</button>
    </form>
  </div>
</section>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-info { display: grid; gap: .8rem; }
  .info-card { display: flex; align-items: center; gap: .7rem; padding: .85rem; }
  .info-card span { width: 2.2rem; height: 2.2rem; border-radius: .7rem; border: 1px solid var(--border); display: grid; place-items: center; background: rgba(34,211,238,.14); transition: transform .2s ease, box-shadow .2s ease; }
  .info-card:hover span { transform: scale(1.06); box-shadow: var(--glow); }
  .info-card svg, .social-band svg { width: 1.1rem; height: 1.1rem; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .info-card h3 { margin: 0; }
  .info-card p { margin: .25rem 0 0; color: var(--muted); }
  .social-band { display: flex; flex-wrap: wrap; gap: .5rem; }
  .social-band a { width: 2.5rem; height: 2.5rem; display: grid; place-items: center; border-radius: .75rem; transition: .2s ease; }
  .social-band a:hover { transform: translateY(-3px); box-shadow: var(--glow); }
  .contact-form { padding: 1rem; display: grid; gap: .75rem; }
  .contact-form label { font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); display: grid; gap: .35rem; }
  .contact-form input, .contact-form textarea { border: 1px solid var(--border); background: rgba(0, 0, 0, 0.2); color: var(--text); border-radius: .6rem; padding: .62rem .7rem; font: inherit; }
  .contact-form input:focus, .contact-form textarea:focus { border-color: rgba(139, 92, 246, .75); box-shadow: 0 0 0 3px rgba(139, 92, 246, .2); outline: none; }
  .contact-form button { border: 0; border-radius: .7rem; padding: .7rem 1rem; color: #fff; background: var(--gradient-main); cursor: pointer; transition: .2s ease; }
  .contact-form button:hover { box-shadow: var(--glow); transform: translateY(-2px); }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; } }
</style>